# --- Hosting cruft (Váš-hosting) ---
/tmp/
/stats/
/_

# --- Generované nabídky (mimo git; privacy = nehádatelný GUID) ---
# Ignoruj vše ve www/ kromě sdílených brand assetů (_assets)
/www/*
!/www/_assets/

# --- OS / editor ---
.DS_Store
Thumbs.db
*.swp
*~

# --- Lokální / citlivé ---
.env
*.local

# --- Vstupní materiály (intake) — mimo git kromě README ---
/podklady/*
!/podklady/README.md
